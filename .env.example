# Anti-Captcha API key for solving reCAPTCHA (listyourself, etc.)
# Copy to .env and add your key: https://anti-captcha.com/clients/settings/apisetup
ANTICAPTCHA_API_KEY=

# Telegram marketplace bot configuration
TELEGRAM_BOT_TOKEN=
ENVIRONMENT=development
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
BTCPAY_URL=
BTCPAY_API_KEY=
BTCPAY_STORE_ID=
BTCPAY_WEBHOOK_SECRET=
WEBHOOK_PUBLIC_BASE_URL=
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
NGROK_AUTHTOKEN=
NGROK_URL=
NGROK_PATH=C:\Program Files\ngrok\ngrok.exe
ORDER_AMOUNT_USD=150
# Set to false to skip payment and submit workflow directly (for testing)
PAYMENT_ENABLED=true
# Fallback for SSN/CPN state when buyer's address state can't be resolved (buyer supplies state in /order)
WORKFLOW_STATE=Florida
WORKFLOW_STOP_AFTER=first_premier
WORKFLOW_CONCURRENCY=3
ADSPOWER_API_BASE=http://127.0.0.1:50325
